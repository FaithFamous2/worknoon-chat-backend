  "description": "Real-time chat backend for Worknoon eCommerce platform. Supports conversations between customers, agents, designers, and merchants.",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest --coverage",
    "test:watch": "jest --watch",
    "lint": "eslint src/",
    "format": "prettier --write src/"
  },
  "keywords": [
